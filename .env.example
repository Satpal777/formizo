# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/formizo

# API runtime
NODE_ENV=development
PORT=9000
BASE_URL=http://localhost:9000
API_BASE_URL=http://localhost:9000
TRUST_PROXY=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:9000/trpc

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Plan limits
DEVELOPER_PLAN_MAX_FORMS=10
PRO_PLAN_MAX_FORMS=unlimited

# Product URLs used by API emails and CORS
ONBOARDING_CTA_URL=http://localhost:3000
EMAIL_VERIFICATION_URL=http://localhost:3000/verify-email

# SMTP email. Leave blank locally to log/skip sending where supported.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
